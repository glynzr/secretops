# All of these can be configured through the UI instead

# Backend
PORT=8080
DB_PATH=./data/secretops.db

# CLI Service
BACKEND_URL=http://backend:8080
CLI_PORT=5001
CONFIDENCE_THRESHOLD=0.70

# AI Keys (fallback — UI config takes priority)
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
DEEPSEEK_API_KEY=sk-...

# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-...

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=security@yourcompany.com
SMTP_PASSWORD=...
EMAIL_RECIPIENTS=security@yourcompany.com,devops@yourcompany.com

# AWS (for IAM key revocation)
ADMIN_AWS_ACCESS_KEY_ID=AKIA...
ADMIN_AWS_SECRET_ACCESS_KEY=...

# GitHub OAuth (for PAT revocation)
GITHUB_OAUTH_CLIENT_ID=...
GITHUB_OAUTH_CLIENT_SECRET=...
