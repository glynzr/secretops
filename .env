# SecretOps Environment Variables
# Copy this file to .env and fill in your values

# ─── Required ─────────────────────────────────────────────────────────────────
# AES-GCM encryption key for stored credentials — MUST be exactly 32 bytes
# Generate: openssl rand -base64 24
ENCRYPTION_KEY=secretops-32-byte-encryption-key!!

# ─── Vault ────────────────────────────────────────────────────────────────────
# Root token for HashiCorp Vault (dev mode default)
VAULT_TOKEN=secretops-root-token
VAULT_ADDR=http://vault:8200

# ─── Service URLs (used inside Docker network) ────────────────────────────────
API_BACKEND_URL=http://api-backend:8080
AI_ENGINE_URL=http://ai-engine:5001

# ─── Optional overrides ───────────────────────────────────────────────────────
# DB_PATH=/data/secretops.db
# CLONE_DIR=/tmp/secretops-repos
